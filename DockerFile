FROM maven:3.9.9-eclipse-temurin-17 AS build
WORKDIR /workspace
COPY tea-stall-app/pom.xml tea-stall-app/pom.xml
COPY tea-stall-app/src tea-stall-app/src
RUN mvn -f tea-stall-app/pom.xml clean package -DskipTests
FROM eclipse-temurin:17-jre
WORKDIR /app
COPY --from=build /workspace/tea-stall-app/target/tea-stall-app-1.0.0.jar app.jar
EXPOSE 8081
ENTRYPOINT ["java", "-jar", "/app/app.jar"]
